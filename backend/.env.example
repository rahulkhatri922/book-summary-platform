# ---- Django ----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Database (PostgreSQL) ----
# docker-compose sets this to the postgres service. For local dev point it at
# your own Postgres. Full-text search requires PostgreSQL (not SQLite).
DATABASE_URL=postgres://postgres:postgres@postgres:5432/booksummaries

# ---- Medium integration ----
# Per-user integration tokens are stored on the user's profile, not here.
# MEDIUM_MOCK=1 makes /publish return a fake Medium URL without calling the API,
# so the cross-post feature is demoable end-to-end without a real token.
MEDIUM_API_BASE=https://api.medium.com/v1
MEDIUM_MOCK=1
